            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('ops signup', function () {",
                  "  pm.expect(pm.response.code).to.equal(201);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('pendingApproval', true);",
                  "});"
                ]
              }
            }
          ]
        },
