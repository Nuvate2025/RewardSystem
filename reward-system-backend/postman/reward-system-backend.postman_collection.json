                    "exec": [
                      "pm.test('stores batchId + preview couponCode', function () {",
                      "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                      "  const json = pm.response.json();",
                      "  if (json && json.batchId) {",
                      "    pm.collectionVariables.set('couponBatchId', String(json.batchId));",
                      "  }",
                      "  if (json && Array.isArray(json.previewCodes) && json.previewCodes[0]) {",
                      "    pm.collectionVariables.set('couponCode', String(json.previewCodes[0]));",
                      "  }",
                      "});"
